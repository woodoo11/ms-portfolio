---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="about-panel">
		<div class="about-grid">
			<div>
				<p class="eyebrow">About</p>
				<h1>Minhas Sajjan</h1>
				<p class="intro">Minhas Sajjan is a SAP Enable Now consultant who is learning web development and building digital learning experiences with a practical mindset.</p>
			</div>

			<div class="about-data">
				<div>
					<h2>What I do</h2>
					<ul>
						<li>Design learning experiences for SAP Enable Now</li>
						<li>Build training content that supports adoption</li>
						<li>Learn modern web tools like Astro and Git</li>
					</ul>
				</div>

				<div>
					<h2>Skills</h2>
					<ul>
						<li>SAP Enable Now consulting</li>
						<li>Instructional design</li>
						<li>Web development fundamentals</li>
						<li>Git-based workflows and deployment</li>
					</ul>
				</div>
			</div>
		</div>

		<div class="contact-card">
			<p>Get in touch or learn more about this portfolio owner.</p>
			<a class="button-link" href="mailto:example@example.com">Email</a>
			<a class="button-link secondary" href="https://github.com/USERNAME" target="_blank">GitHub profile</a>
		</div>
	</section>

	<style>
		.about-panel {
			background: #ffffff;
			border-radius: 32px;
			padding: 2.5rem;
			box-shadow: 0 28px 60px rgba(15, 23, 42, 0.08);
		}

		.about-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.eyebrow {
			text-transform: uppercase;
			color: #7b4a3a;
			letter-spacing: 0.2em;
			font-size: 0.75rem;
			margin-bottom: 1rem;
		}

		h1 {
			font-size: 2.75rem;
			margin: 0;
		}

		.intro {
			font-size: 1.05rem;
			line-height: 1.8;
			color: #7b4a3a;
			max-width: 42rem;
		}

		.about-data h2 {
			font-size: 1.2rem;
			margin-bottom: 0.75rem;
		}

		.about-data ul {
			list-style: disc;
			margin: 0;
			padding-left: 1.25rem;
			color: #7b4a3a;
			line-height: 1.8;
		}

		.about-data li {
			margin-bottom: 0.75rem;
		}

		.contact-card {
			margin-top: 2rem;
			padding: 1.75rem;
			border-radius: 20px;
			background: #e2c6b5;
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}

		.contact-card p {
			margin: 0;
			font-size: 1rem;
			color: #4e2b1e;
		}

		.button-link {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.85rem 1.4rem;
			border-radius: 9999px;
			text-decoration: none;
			font-weight: 600;
			color: #ffffff;
			background: #7b4a3a;
			width: fit-content;
		}

		.button-link.secondary {
			background: #c8a48a;
			color: #4e2b1e;
		}

		@media (max-width: 860px) {
			.about-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Layout>

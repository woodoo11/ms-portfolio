---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section>
		<h1>About Me</h1>
		<p>
			I am a SAP Enable Now consultant learning web development and building a portfolio website with Astro.
		</p>

		<h2>What I Do</h2>
		<ul>
			<li>Designing learning experiences for SAP Enable Now</li>
			<li>Building user-friendly training content</li>
			<li>Learning modern web development with Astro</li>
		</ul>

		<h2>Skills</h2>
		<ul>
			<li>SAP Enable Now consulting</li>
			<li>Instructional design</li>
			<li>Web development basics</li>
			<li>Git + deployment workflows</li>
		</ul>

		<h2>Contact</h2>
		<p>
			Reach me at <a href="mailto:minhassajjan@gmail.com">minhassajjan@gmail.com</a> or visit my
			<a href="https://github.com/woodoo11" target="_blank">GitHub</a>.
		</p>
	</section>

	<style>
		section {
			background: white;
			border-radius: 16px;
			padding: 2rem;
			box-shadow: 0 20px 40px rgba(15, 23, 42, 0.05);
		}

		h1 {
			font-size: 2.5rem;
			margin-bottom: 1rem;
		}

		p,
		ul {
			font-size: 1.05rem;
			line-height: 1.8;
		}

		ul {
			padding-left: 1.25rem;
		}

		li {
			margin-bottom: 0.5rem;
		}

		a {
			color: #2563eb;
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}
	</style>

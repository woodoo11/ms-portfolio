---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="projects-panel">
		<header class="projects-header">
			<div>
				<p class="eyebrow">Projects</p>
				<h1>Work in progress</h1>
				<p>Learning projects and training work that demonstrate my progress in web development and digital learning.</p>
			</div>
		</header>

		<div class="projects-grid">
			<article class="project-card">
				<h2>Portfolio Website</h2>
				<p>A portfolio website built with Astro and deployed on Cloudflare Pages. This site showcases the owner’s work and skills.</p>
				<a href="https://github.com/USERNAME" target="_blank">View project</a>
			</article>

			<article class="project-card">
				<h2>SAP Learning Materials</h2>
				<p>Training and learning content for SAP Enable Now, crafted to improve adoption and user success.</p>
				<a href="https://github.com/USERNAME" target="_blank">View GitHub</a>
			</article>

			<article class="project-card">
				<h2>Learning Notes</h2>
				<p>Notes and experiments about web development, Git workflows, and deploying projects to the web.</p>
				<a href="https://github.com/USERNAME" target="_blank">View GitHub</a>
			</article>
		</div>
	</section>

	<style>
		.projects-panel {
			background: white;
			border-radius: 32px;
			padding: 2.5rem;
			box-shadow: 0 28px 60px rgba(15, 23, 42, 0.08);
		}

		.projects-header {
			margin-bottom: 2rem;
		}

		.eyebrow {
			text-transform: uppercase;
			letter-spacing: 0.2em;
			font-size: 0.75rem;
			color: #2563eb;
			margin-bottom: 0.75rem;
		}

		h1 {
			font-size: 2.5rem;
			margin: 0;
		}

		.projects-header p {
			color: #475569;
			font-size: 1.05rem;
			line-height: 1.8;
			max-width: 42rem;
		}

		.projects-grid {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.5rem;
		}

		.project-card {
			padding: 1.75rem;
			border-radius: 24px;
			background: #f8fafc;
			border: 1px solid rgba(148, 163, 184, 0.25);
		}

		.project-card h2 {
			margin-top: 0;
			font-size: 1.2rem;
			margin-bottom: 0.75rem;
		}

		.project-card p {
			margin: 0;
			line-height: 1.8;
			color: #475569;
		}

		.project-card a {
			display: inline-block;
			margin-top: 1.25rem;
			font-weight: 600;
			color: #2563eb;
			text-decoration: none;
		}

		.project-card a:hover {
			text-decoration: underline;
		}

		@media (max-width: 900px) {
			.projects-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Layout>

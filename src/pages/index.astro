---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <main>
        <h1>Minhas Sajjan</h1>
        <p class="subtitle">Freelance Learning Developer & SAP Enable Now Consultant</p>
        <p class="bio">
            Training and learning enthusiast with experience in designing and developing learning solutions to meet organizational needs. Skilled in collaborating with 
global teams and leading small groups independently. Maintain powerful rapport with key stakeholders and consultants.
        </p>
        
        <div class="links">
            <a href="https://github.com/woodoo11" target="_blank">GitHub</a>
            <a href="mailto:minhassajjan@gmail.com">Email</a>
        </div>
    </main>

    <style>
        main {
            max-width: 800px;
            margin: 4rem auto;
            padding: 2rem;
            text-align: center;
        }
        
        h1 {
            font-size: 3rem;
            margin-bottom: 0.5rem;
        }
        
        .subtitle {
            font-size: 1.5rem;
            color: #666;
            margin-bottom: 1rem;
        }
        
        .bio {
            font-size: 1.1rem;
            margin: 2rem 0;
        }
        
        .links {
            margin-top: 2rem;
        }
        
        a {
            display: inline-block;
            margin: 0 1rem;
            padding: 0.5rem 1rem;
            background: #0066ff;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            transition: background 0.3s;
        }
        
        a:hover {
            background: #0052cc;
        }
    </style>
</Layout>
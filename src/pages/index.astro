---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="hero-card">
		<div class="hero-copy">
			<p class="eyebrow">Portfolio</p>
			<h1>Minhas Sajjan</h1>
			<p class="hero-subtitle">A clean, modern portfolio for showcasing projects, skills, and contact details.</p>

			<div class="hero-actions">
				<a class="primary-button" href="https://github.com/USERNAME" target="_blank">View GitHub</a>
				<a class="secondary-button" href="mailto:example@example.com">Email</a>
			</div>
		</div>
	</section>

	<section class="feature-grid">
		<div class="feature-card">
			<h2>Expertise</h2>
			<p>Helping teams learn SAP Enable Now through practical, user-friendly training solutions.</p>
		</div>

		<div class="feature-card">
			<h2>Learning</h2>
			<p>Building a portfolio site with Astro and deploying it live using Cloudflare Pages.</p>
		</div>

		<div class="feature-card">
			<h2>Focus</h2>
			<p>Creating clean, modern design and improving my developer workflow with Git and deployment.</p>
		</div>
	</section>

	<style>
		.hero-card {
			background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%);
			color: white;
			border-radius: 32px;
			padding: 3rem 2rem;
			box-shadow: 0 30px 60px rgba(15, 23, 42, 0.12);
			margin-bottom: 2rem;
		}

		.hero-copy {
			max-width: 720px;
			margin: 0 auto;
			text-align: center;
		}

		.eyebrow {
			text-transform: uppercase;
			letter-spacing: 0.25em;
			font-size: 0.8rem;
			opacity: 0.85;
			margin-bottom: 1rem;
		}

		h1 {
			font-size: clamp(3rem, 6vw, 4.5rem);
			margin: 0;
			line-height: 1.05;
		}

		.hero-subtitle {
			font-size: 1.1rem;
			max-width: 720px;
			margin: 1.5rem auto 0;
			line-height: 1.85;
			color: #dbeafe;
		}

		.hero-actions {
			margin-top: 2.5rem;
			display: flex;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.75rem;
		}

		.primary-button,
		.secondary-button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.95rem 1.6rem;
			border-radius: 9999px;
			font-weight: 600;
			text-decoration: none;
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

		.primary-button {
			background: white;
			color: #1d4ed8;
		}

		.secondary-button {
			background: rgba(255, 255, 255, 0.18);
			color: white;
			border: 1px solid rgba(255, 255, 255, 0.35);
		}

		.primary-button:hover,
		.secondary-button:hover {
			transform: translateY(-1px);
			box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
		}

		.feature-grid {
			display: grid;
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1.25rem;
		}

		.feature-card {
			background: white;
			border-radius: 24px;
			padding: 2rem;
			box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
		}

		.feature-card h2 {
			margin: 0 0 0.75rem;
			font-size: 1.25rem;
		}

		.feature-card p {
			margin: 0;
			color: #475569;
			line-height: 1.8;
		}

		@media (max-width: 820px) {
			.feature-grid {
				grid-template-columns: 1fr;
			}
		}
	</style>
</Layout>